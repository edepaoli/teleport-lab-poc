.env

# Runtime state and logs generated by Docker/Teleport.
vault-log/logs/**
!vault-log/logs/.gitkeep

# Local OpenBao bootstrap material: unseal keys and root tokens.
vault-log/openbao/bootstrap/**
!vault-log/openbao/bootstrap/.gitkeep

# Local self-signed proxy certificates.
teleport/proxy-a/certs/*
teleport/proxy-b/certs/*
!teleport/proxy-a/certs/.gitkeep
!teleport/proxy-b/certs/.gitkeep

# OS/editor noise.
.DS_Store
*.swp
